rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Predictions: users can read/write their own
    match /predictions/{predictionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Only server-side resolution updates are allowed (via admin SDK)
      // For client-side demo, allow update of own predictions
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // User stats: readable by all authenticated users (for leaderboard)
    match /userStats/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }
  }
}
